<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- LocalDate bean - gets current date using factory method -->
    <bean id="currentDate" 
          class="java.time.LocalDate" 
          factory-method="now" />

    <!-- DiscountCalculator bean with Setter Injection -->
    <bean id="discountCalculator" 
          class="com.discount.DiscountCalculator">

        <!-- Setter-based Dependency Injection -->
        <property name="currentDate" ref="currentDate" />
        <property name="price" value="100.0" />

    </bean>

</beans>